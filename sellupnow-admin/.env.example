# ═══════════════════════════════════════════════════════════════════════════════
# SellUpNow Admin — Environment Template
# Copy this file to .env and fill in the values for your deployment.
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME=SellUpNow
APP_ENV=production
APP_KEY=                            # run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://admin.yourdomain.com
APP_VERSION="1.0.0"

# URL of the ListOcean customer-facing site
CUSTOMER_WEB_URL=https://yourdomain.com

# Absolute path to the ListOcean /public folder on this server
# (used to resolve upload file paths for display in the admin)
LISTOCEAN_PUBLIC_PATH=/var/www/listocean/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─────────────────────────────────────────────────────────────────────────────
# SellUpNow Admin own database
# SQLite is fine for small single-server setups.  Swap to mysql for HA setups.
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# --- or for MySQL: ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sellupnow_admin
# DB_USERNAME=db_user
# DB_PASSWORD=db_password

# ─────────────────────────────────────────────────────────────────────────────
# ListOcean bridge connection
# After running the ListOcean installer at https://yourdomain.com/install,
# set these to the SAME MySQL credentials you entered in that wizard.
# Leave LISTOCEAN_DB_CONNECTION unset (or = sqlite) for local SQLite dev only.
# ─────────────────────────────────────────────────────────────────────────────
LISTOCEAN_DB_CONNECTION=mysql
LISTOCEAN_DB_HOST=127.0.0.1
LISTOCEAN_DB_PORT=3306
LISTOCEAN_DB_DATABASE=listocean       # same DB name entered in ListOcean installer
LISTOCEAN_DB_USERNAME=listocean_user
LISTOCEAN_DB_PASSWORD=

# Only needed on Windows VPS or servers with missing CA bundles:
# LISTOCEAN_MYSQL_ATTR_SSL_CA=/path/to/cacert.pem

# ─────────────────────────────────────────────────────────────────────────────
# Cache / Queue / Session — use redis/database in production for multi-server
# ─────────────────────────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─────────────────────────────────────────────────────────────────────────────
# Mail
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# Pusher (real-time chat notifications — optional)
# ─────────────────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─────────────────────────────────────────────────────────────────────────────
# Optional integrations
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

APP_TIMEZONE=UTC

# ─────────────────────────────────────────────────────────────────────────────
# Redis (if CACHE_DRIVER / QUEUE_CONNECTION / SESSION_DRIVER = redis)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# ─────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (Push Notifications)
# ─────────────────────────────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Paystack
# ─────────────────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PayPal
# ─────────────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com